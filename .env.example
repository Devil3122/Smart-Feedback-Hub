# PostgreSQL Database URL (Connection Pooling / Serverless compatible, e.g. Neon, Supabase)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Super Admin Credentials
ADMIN_USERNAME="Devil"
ADMIN_PASSWORD_HASH="salt:hashed_password"

# AI/Language Model Services API Keys (Whisper & Sentiment Analysis)
WHISPER_API_KEY="your-whisper-api-key"
SENTIMENT_API_KEY="your-sentiment-analysis-key"

# Cloud Storage Configuration (Vercel Blob / AWS S3 / Supabase Storage)
# If using Vercel Blob, set this write token in Vercel environment settings
VERCEL_BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Application Settings
APP_URL="https://smart-feedback-hub.vercel.app"
PING_MESSAGE="ping pong"
